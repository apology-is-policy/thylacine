+			__syscall(SYS_close, ctl);
+			return -1;                 /* errno = EMFILE from alloc */
+		}
+		struct pouch_sock_slot *slot = pouch_sock_resolve(fd);
+		slot->family    = POUCH_SOCK_FAM_INET;
+		slot->net_proto = proto;
+		slot->ctl_fd    = ctl;
+		slot->conn_n    = n;
+		return fd;
+	}
