+/* ---- net-5: AF_INET over /net helpers ------------------------------- *
+ *
+ * All paths are absolute "/net/<proto>/..." resolved by the kernel's stalk
+ * against the Proc's namespace (where joey mounts netd's /net). No new
+ * syscall: SYS_open / SYS_read / SYS_write / SYS_close only. */
+
+/* Append the decimal of v to buf at pos; returns the new pos. The callers
+ * size their buffers for the worst case (a connection number < 2^24 = 8
+ * digits, ports <= 5 digits, octets <= 3). */
+static int net_put_dec(char *buf, int pos, unsigned int v)
+{
+    char tmp[10];
+    int  t = 0;
+    if (v == 0) { buf[pos++] = '0'; return pos; }
+    while (v > 0 && t < 10) { tmp[t++] = (char)('0' + (v % 10u)); v /= 10u; }
+    while (t > 0) buf[pos++] = tmp[--t];
+    return pos;
+}
+
+/* Write "/net/tcp/" or "/net/udp/" into buf; returns the byte count (9). */
+static int net_proto_prefix(char *buf, int proto)
+{
+    const char *p = (proto == POUCH_NET_UDP) ? "/net/udp/" : "/net/tcp/";
+    int i = 0;
+    while (p[i]) { buf[i] = p[i]; i++; }
+    return i;
+}
+
+/* Build "/net/<proto>/<n>/<file>" into buf (cap bytes), NUL-terminated.
+ * Returns the length (excluding NUL) or -1 on overflow. */
+static int net_conn_path(char *buf, int cap, int proto, int n, const char *file)
+{
+    int pos = net_proto_prefix(buf, proto);
+    pos = net_put_dec(buf, pos, (unsigned int)n);
+    if (pos >= cap - 1) return -1;
+    buf[pos++] = '/';
+    for (int i = 0; file[i]; i++) {
+        if (pos >= cap - 1) return -1;
+        buf[pos++] = file[i];
+    }
+    buf[pos] = '\0';
+    return pos;
+}
+
+int pouch_net_read_dec(int fd, int *out_n)
+{
+    char b[16];
+    long r = __syscall(SYS_read, fd, b, (size_t)(sizeof b - 1));
+    if (r <= 0) return -1;
+    unsigned int v = 0;
+    int any = 0;
+    for (long i = 0; i < r; i++) {
+        if (b[i] < '0' || b[i] > '9') break;
+        v = v * 10u + (unsigned int)(b[i] - '0');
+        any = 1;
+        if (v >= (1u << 24)) return -1;   /* netd N_MASK bound; reject garbage */
+    }
+    if (!any) return -1;
+    *out_n = (int)v;
+    return 0;
+}
+
+int pouch_net_clone(int proto, int *out_n)
+{
+    char path[24];
+    int  pos = net_proto_prefix(path, proto);
+    const char *c = "clone";
+    for (int i = 0; c[i]; i++) path[pos++] = c[i];
+    path[pos] = '\0';
+    long fd = __syscall(SYS_open, (long)-1, path, (size_t)pos, (long)POUCH_SRV_ORDWR);
+    if (fd < 0) { errno = ENETDOWN; return -1; }
+    if (pouch_net_read_dec((int)fd, out_n) < 0) {
+        __syscall(SYS_close, fd);
+        errno = ENETDOWN;
+        return -1;
+    }
+    return (int)fd;
+}
+
+int pouch_net_open_conn_file(int proto, int n, const char *file, int omode)
+{
+    char path[64];
+    int  pos = net_conn_path(path, (int)sizeof path, proto, n, file);
+    if (pos < 0) { errno = EINVAL; return -1; }
+    long fd = __syscall(SYS_open, (long)-1, path, (size_t)pos, (long)omode);
+    if (fd < 0) return -1;   /* caller sets the POSIX errno (data vs listen) */
+    return (int)fd;
+}
+
+int pouch_net_cmd_ipport(char *cmd, const char *verb,
+                         const unsigned char ip4[4], unsigned int port)
+{
+    int pos = 0;
+    for (int i = 0; verb[i]; i++) cmd[pos++] = verb[i];
+    cmd[pos++] = ' ';
+    for (int i = 0; i < 4; i++) {
+        pos = net_put_dec(cmd, pos, ip4[i]);
+        if (i < 3) cmd[pos++] = '.';
+    }
+    cmd[pos++] = '!';
+    pos = net_put_dec(cmd, pos, port);
+    return pos;
+}
+
+int pouch_net_cmd_anyport(char *cmd, unsigned int port)
+{
+    const char *v = "announce *!";
+    int pos = 0;
+    for (int i = 0; v[i]; i++) cmd[pos++] = v[i];
+    pos = net_put_dec(cmd, pos, port);
+    return pos;
+}
+
+int pouch_net_read_endpoint(int proto, int n, const char *file,
+                            unsigned char out_ip4[4], unsigned int *out_port)
+{
+    int fd = pouch_net_open_conn_file(proto, n, file, (int)POUCH_SRV_OREAD);
+    if (fd < 0) return -1;
+    char b[40];
+    long r = __syscall(SYS_read, fd, b, (size_t)(sizeof b - 1));
+    __syscall(SYS_close, fd);
+    if (r <= 0) return -1;
+
+    /* Parse "a.b.c.d!port". */
+    long pos = 0;
+    unsigned int oct[4];
+    for (int oi = 0; oi < 4; oi++) {
+        unsigned int v = 0;
+        int any = 0;
+        while (pos < r && b[pos] >= '0' && b[pos] <= '9') {
+            v = v * 10u + (unsigned int)(b[pos] - '0');
+            any = 1;
+            pos++;
+            if (v > 255) return -1;
+        }
+        if (!any) return -1;
+        oct[oi] = v;
+        if (oi < 3) {
+            if (pos >= r || b[pos] != '.') return -1;
+            pos++;
+        }
+    }
+    if (pos >= r || b[pos] != '!') return -1;
+    pos++;
+    unsigned int port = 0;
+    int any = 0;
+    while (pos < r && b[pos] >= '0' && b[pos] <= '9') {
+        port = port * 10u + (unsigned int)(b[pos] - '0');
+        any = 1;
+        pos++;
+        if (port > 65535u) return -1;
+    }
+    if (!any) return -1;
+    for (int i = 0; i < 4; i++) out_ip4[i] = (unsigned char)oct[i];
+    *out_port = port;
+    return 0;
+}
