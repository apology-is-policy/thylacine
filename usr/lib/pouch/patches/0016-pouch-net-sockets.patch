 int socket(int domain, int type, int protocol)
 {
+	/* net-5: AF_INET over /net (NET-DESIGN section 7). SOCK_STREAM ->
+	 * /net/tcp, SOCK_DGRAM -> /net/udp. socket() eagerly opens the
+	 * protocol's clone file (the Plan 9 connection factory, NET-DESIGN
+	 * 3.2/4): the opened fid is the connection's ctl, reading it yields
+	 * the connection number N. ctl + N are held in the slot for the
+	 * socket's lifetime; connect()/accept() open the data stream. */
+	if (domain == AF_INET) {
+		int nbase = type & ~(SOCK_CLOEXEC | SOCK_NONBLOCK);
+		int proto;
+		if (nbase == SOCK_STREAM)     proto = POUCH_NET_TCP;
+		else if (nbase == SOCK_DGRAM) proto = POUCH_NET_UDP;
+		else { errno = EPROTONOSUPPORT; return -1; }
+
+		/* protocol 0 = the family default; accept the explicit
+		 * IPPROTO_TCP(6)/IPPROTO_UDP(17) matching the type, reject the
+		 * rest (P-3: no silently-wrong POSIX). */
+		if (protocol != 0
+		    && !(proto == POUCH_NET_TCP && protocol == 6)
+		    && !(proto == POUCH_NET_UDP && protocol == 17)) {
+			errno = EPROTONOSUPPORT;
+			return -1;
+		}
+
