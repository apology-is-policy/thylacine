-	to = to ? (void *)(long[]){CLAMP(s), ns} : 0;
-#endif
-	r = __syscall_cp(SYS_futex, addr, op, val, to);
-	if (r != -ENOSYS) return r;
-	return __syscall_cp(SYS_futex, addr, op & ~FUTEX_PRIVATE, val, to);
+	(void)op;
+	long timeout_us;
+	if (!to) {
+		timeout_us = -1L;
+	} else if (to->tv_sec < 0) {
+		/* Negative relative deadline => already past => immediate timeout.
+		 * torpor returns ETIMEDOUT for timeout_us = 0. */
+		timeout_us = 0;
+	} else {
+		/* F1+F3 audit close: clamp at TORPOR_MAX_TIMEOUT_US (= 1 hour in
+		 * microseconds, per kernel/torpor.h). The kernel REJECTS
+		 * timeout_us > TORPOR_MAX_TIMEOUT_US with -EINVAL, which
+		 * __timedwait_cp would then translate to "no error, no wait" via
+		 * the "if (r != EINTR && r != ETIMEDOUT && r != ECANCELED) r = 0"
+		 * dispatch — producing an infinite spin in pthread_cond_timedwait
+		 * when the caller's absolute deadline is far in the future. Cap
+		 * here so torpor returns ETIMEDOUT cleanly; the caller's outer
+		 * loop re-evaluates the absolute deadline and re-enters with a
+		 * fresh sub-1-hour relative timespec.
