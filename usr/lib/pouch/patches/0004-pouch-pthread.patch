+		 * 3600 * 1e6 = 3.6e9 (well within signed long range). */
+		long max_us = 3600L * 1000000L;
+		if (to->tv_sec >= 3600L) {
+			timeout_us = max_us;
+		} else {
+			timeout_us = (long)to->tv_sec * 1000000L + (long)(to->tv_nsec / 1000);
+			if (timeout_us > max_us) timeout_us = max_us;
+		}
+	}
+	return __syscall_cp(SYS_torpor_wait, addr, val, timeout_us);
