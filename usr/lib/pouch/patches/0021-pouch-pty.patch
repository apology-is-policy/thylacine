+/* pouch — the tty ioctl dispatcher (PTY-3, the pouch pty boundary-line).
+ *
+ * Replaces musl's Linux ioctl.c (a raw SYS_ioctl passthrough plus a
+ * time64 compat map — both dead on Thylacine: __NR_ioctl is the 0xFFFF
+ * -ENOSYS sentinel and there is no kernel ioctl surface). Thylacine's
+ * terminal control is file- and syscall-shaped instead:
+ *
+ *   - per-pts termios + winsize live in the ptyfs ctl file
+ *     /dev/pts/<n>ctl (the PTY-2c grammar: five "+name"/"-name" flag
+ *     tokens icanon/echo/isig/icrnl/onlcr + "winsize <cols> <rows>");
+ *   - the controlling-terminal ops are kernel syscalls keyed on the
+ *     caller's own fd (PTY-1d: SYS_TTY_ACQUIRE/SET_FG/GET_FG);
+ *   - ptsname is a qid decode: a ptyfs endpoint qid encodes
+ *     PTS_FLAG(bit 40) | N<<8 | filekind, carried VERBATIM in
+ *     t_stat.qid_path (SYS_FSTAT).
+ *
+ * This dispatcher translates the POSIX tty ioctl families onto those
+ * three mechanisms, which makes the UNPATCHED musl wrappers work:
+ * tcgetattr/tcsetattr (TCGETS/TCSETS*), tcgetpgrp/tcsetpgrp
+ * (TIOCGPGRP/TIOCSPGRP), tcgetwinsize/tcsetwinsize + isatty
+ * (TIOCGWINSZ/TIOCSWINSZ), unlockpt (TIOCSPTLCK), ptsname_r (TIOCGPTN),
+ * openpty (all of the above).
+ *
+ * Is-a-pts discrimination: fstat the fd; a pts endpoint reports
+ * S_IFCHR (the ptyfs PTY-3 posture — a pts node IS a character device,
+ * the Linux model) AND a PTS_FLAG qid with filekind master/slave. The
+ * S_ISCHR gate is load-bearing: netd's /net qids also use bit 40
+ * (CONN_FLAG) but netd reports S_IFREG, so a socket fd can never pass.
+ * A tagged pouch socket fd (POUCH_SOCK_TAG) is rejected up front.
+ *
+ * Errno posture:
+ *   - unknown request (any fd): ENOTTY (the Linux convention — Linux
+ *     answers ENOTTY for unsupported ioctls even on real ttys; the
+ *     pre-PTY-3 pouch answered ENOSYS for ALL ioctls).
+ *   - tty request on a non-pts fd: ENOTTY. fstat failure is folded
+ *     into ENOTTY too — the kernel SYS_FSTAT answers a bare -1 for
+ *     both a bad fd and a valid statless fd (pipe/cons/notes), so
+ *     EBADF cannot be distinguished here. Documented nit: a closed fd
+ *     yields ENOTTY, not EBADF (musl's isatty() normalizes to ENOTTY
+ *     anyway, so the app-visible isatty behavior is identical).
+ *   - kernel tty-syscall errors pass through the standard seam decode
+ *     (T_E_* values are POSIX-aligned). One documented divergence: the
+ *     kernel's EPERM contours answer EACCES (the errno.h -1-alias
+ *     rule, PTY-1d), so tcsetpgrp's POSIX-EPERM cases read as EACCES.
+ *   - TCFLSH (tcflush): ENOTSUP — the ctl grammar has no flush verb at
+ *     v1.0 (a silent success would lie about queued bytes). v1.x seam.
+ *   - TIOCGSID / TIOCNOTTY: ENOTSUP (no kernel surface; acquisition is
+ *     explicit and session-scoped, PTY-1d).
+ *   - TCSBRK/TCSBRKP (tcdrain + tcsendbreak): 0 on a pts. Drain is
+ *     genuinely complete-on-return here — a slave write lands in the
+ *     master-side ring before the Twrite returns (the PTY-2 synchronous
+ *     ring model; there is no hardware output queue). BREAK has no pts
+ *     representation (as on Linux pts pairs, where a break is invisible
+ *     to the slave without pktmode — which does not exist here).
+ *
+ * termios subset honesty: exactly the five ldisc flags survive the
+ * translation (ICANON/ECHO/ISIG in c_lflag; ICRNL in c_iflag;
+ * OPOST+ONLCR in c_oflag). Every other termios bit and every c_cc slot
+ * is accepted-and-ignored on set, and reported at a fixed plausible
+ * cooked baseline on get (the fixed control chars are the ldisc's:
+ * VINTR=^C VQUIT=^\ VSUSP=^Z, VERASE=DEL [the ldisc erases on BS and
+ * DEL], VMIN=1 VTIME=0; VEOF/VKILL report 0 — not implemented).
+ * cfmakeraw + tcsetattr works because it clears exactly the five
+ * honored flags (via OPOST for onlcr).
+ */
+
 #include <sys/ioctl.h>
+#include <termios.h>
+#include <fcntl.h>
+#include <unistd.h>
 #include <stdarg.h>
