+++ b/src/process/posix_spawnp.c	2026-07-23 19:42:44
@@ -1,13 +1,51 @@
+/* pouch boundary-line: posix_spawnp -- PATH search then posix_spawn (Clade
+ * CL-1b). Upstream sets attr.__fn to the in-child PATH-searching exec, but
+ * the CL-1b posix_spawn has no child hook (it resolves file_actions
+ * statically), so the search is done here in the parent: a name with '/' is
+ * used verbatim; a bare name is looked up in $PATH (now populated from /env
+ * by the pouch-env crt) via access(X_OK), and the first hit is spawned. */
 #include <spawn.h>
 #include <unistd.h>
+#include <string.h>
+#include <errno.h>
+#include <stdlib.h>
 
+/* Local path bound (avoids a limits.h dependency; the kernel SYS_OPEN_PATH_MAX is 1024). */
+#define PSPAWNP_PATH_MAX 4096
+
 int posix_spawnp(pid_t *restrict res, const char *restrict file,
 	const posix_spawn_file_actions_t *fa,
 	const posix_spawnattr_t *restrict attr,
 	char *const argv[restrict], char *const envp[restrict])
 {
-	posix_spawnattr_t spawnp_attr = { 0 };
-	if (attr) spawnp_attr = *attr;
-	spawnp_attr.__fn = (void *)__execvpe;	
-	return posix_spawn(res, file, fa, &spawnp_attr, argv, envp);
+	if (!file || !file[0]) return EINVAL;
+	if (strchr(file, '/'))
+		return posix_spawn(res, file, fa, attr, argv, envp);
+
+	const char *path = getenv("PATH");
+	if (!path || !*path) path = "/bin:/usr/bin";
+	size_t flen = strlen(file);
+	char buf[PSPAWNP_PATH_MAX];
+	int seen_eacces = 0;
+
+	for (const char *p = path; ; ) {
+		const char *colon = strchr(p, ':');
+		size_t dlen = colon ? (size_t)(colon - p) : strlen(p);
+		if (dlen == 0) {                       /* empty element = cwd */
+			if (flen + 1 > sizeof buf) goto next;
+			memcpy(buf, file, flen + 1);
+		} else {
+			if (dlen + 1 + flen + 1 > sizeof buf) goto next;
+			memcpy(buf, p, dlen);
+			buf[dlen] = '/';
+			memcpy(buf + dlen + 1, file, flen + 1);
+		}
