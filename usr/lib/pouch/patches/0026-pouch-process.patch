@@ -0,0 +1,73 @@
+/* pouch boundary-line: shared process-lifecycle helpers (Clade CL-1b). See
+ * _pouch_process.h. */
+#include <errno.h>
+#include <sys/wait.h>
+#include "syscall.h"
+#include "_pouch_process.h"
+
+/* __pouch_pipe -- SYS_PIPE returns two fds (read in x0, write in x1), which
+ * musl's __syscall (single x0 result) cannot capture, so this is a bespoke
+ * 2-register svc shim (the native t_pipe shape). On failure the kernel puts
+ * -1 in x0 and leaves x1 unmodified. */
+hidden int __pouch_pipe(int fd[2])
+{
+	register long x8 __asm__("x8") = SYS_thyla_pipe;
+	register long x0 __asm__("x0");
+	register long x1 __asm__("x1");
+	__asm__ __volatile__ ("svc 0"
+		: "=r"(x0), "=r"(x1)
+		: "r"(x8)
+		: "memory");
+	if (x0 < 0) {
+		/* The kernel returns a flat -1 (per-Proc fd/table exhaustion or
+		 * OOM); EMFILE is the closest POSIX errno for pipe(2). */
+		errno = EMFILE;
+		return -1;
+	}
+	fd[0] = (int)x0;
+	fd[1] = (int)x1;
+	return 0;
+}
+
+/* __pouch_wait -- waitpid/wait4 over SYS_WAIT_PID. Two translations are
+ * load-bearing:
+ *
+ *  (1) FLAGS. The kernel WAIT_* values differ from Linux musl's: WCONTINUED
+ *      is 8 (musl) vs 4 (kernel), and the kernel REJECTS unknown flag bits
+ *      with -1. So the option word is mapped bit-by-bit, and any bit outside
+ *      the three POSIX options is dropped.
+ *
+ *  (2) STATUS. For a plain wait (no job-control flag) the kernel writes the
+ *      RAW exit_status (0 = ok, 1 = any error -- v1.0 collapses non-zero to
+ *      1). musl's W* macros decode the Linux status word, so this repacks it
+ *      as WAIT_STATUS_EXITED: (raw & 0xff) << 8 -> WIFEXITED is true and
+ *      WEXITSTATUS == raw. When a job-control flag was passed the kernel
+ *      already returns the Linux-layout packed word (exited/stopped/
+ *      continued), so it is forwarded verbatim.
+ *
+ * Returns the reaped pid (>0), 0 for WNOHANG-with-no-ready-child, or -1 with
+ * errno = ECHILD (the kernel returns a flat -1; ECHILD is the POSIX errno for
+ * "no matching child", the reachable case here). */
+hidden int __pouch_wait(int pid, int *status, int options)
+{
+	unsigned long tf = 0;
+	if (options & WNOHANG)    tf |= POUCH_WAIT_WNOHANG;
+	if (options & WUNTRACED)  tf |= POUCH_WAIT_UNTRACED;
+	if (options & WCONTINUED) tf |= POUCH_WAIT_CONTINUED;
+
+	int raw = 0;
+	long r = __syscall3(SYS_thyla_wait_pid, pid, (long)tf, (long)&raw);
+	if (r < 0) {
+		errno = ECHILD;
+		return -1;
+	}
+	if (r == 0) return 0;   /* WNOHANG: no reapable child; *status untouched */
+
+	if (status) {
+		if (tf & (POUCH_WAIT_UNTRACED | POUCH_WAIT_CONTINUED))
+			*status = raw;                 /* already Linux-packed */
+		else
+			*status = (raw & 0xff) << 8;   /* pack raw exit code as "exited" */
+	}
+	return (int)r;
+}
