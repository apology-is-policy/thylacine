+/* pouch boundary-line: process-lifecycle substrate (Clade CL-1b). Shared by
+ * posix_spawn / posix_spawnp / waitpid / wait4 / pipe / pipe2 / dup2 / dup3.
+ *
+ * The includer MUST pull "syscall.h" (-> features.h -> `hidden`) BEFORE this
+ * header; the SYS_thyla_* numbers below are the local-define idiom (0019/0024
+ * precedent -- aarch64 LP64 has no legacy syscall aliases to repoint, so
+ * naming them here avoids churning bits/syscall.h.in). Each is an EXISTING,
+ * already-audited Thylacine kernel syscall; CL-1b adds ZERO new kernel
+ * surface -- there is no fork/execve on Thylacine, so posix_spawn resolves
+ * its file_actions STATICALLY into the positional spawn fd_list.
+ */
+#ifndef POUCH_PROCESS_H
+#define POUCH_PROCESS_H
+
+/* Thylacine kernel syscall numbers (kernel/include/thylacine/syscall.h). */
+#define SYS_thyla_spawn_full_argv 49  /* struct sys_spawn_args* -> pid / -1   */
+#define SYS_thyla_wait_pid        22  /* (want_pid, flags, status_va) -> pid  */
+#define SYS_thyla_pipe             8  /* () -> rd in x0, wr in x1             */
+#define SYS_thyla_dup             12  /* (oldfd, new_rights) -> newfd (lowest)*/
+#define SYS_thyla_close           11  /* (fd) -> 0 / -1                       */
+
+/* Kernel spawn bounds (SYS_SPAWN_* in syscall.h). */
+#define POUCH_SPAWN_NAME_MAX      256u
+#define POUCH_SPAWN_MAX_FDS        16u
+#define POUCH_SPAWN_ARGV_MAX      512u
+#define POUCH_SPAWN_ARGV_DATA_MAX 65536u
+
+/* Kernel WAIT_* flag values (proc.h). NOTE: WAIT_CONTINUED is 4, but Linux
+ * musl's WCONTINUED is 8 -- the wait shim translates, it does not pass raw. */
+#define POUCH_WAIT_WNOHANG   1u
+#define POUCH_WAIT_UNTRACED  2u
+#define POUCH_WAIT_CONTINUED 4u
+
+/* Handle rights (handle.h) for posix_spawn's std-fd existence probe. There is
+ * no rights-independent fd-existence check (a 0-rights dup is rejected by
+ * valid_alloc_args, and the source's own rights -- needed as a subset -- are
+ * unknown), but a std fd is a byte-I/O Spoor with READ and/or WRITE, so
+ * probing with each detects existence. */
+#define POUCH_RIGHT_READ  1u
+#define POUCH_RIGHT_WRITE 2u
+
+/* struct sys_spawn_args -- the SYS_SPAWN_FULL_ARGV wire type. Mirrors the
+ * kernel layout EXACTLY (96 bytes; the _Static_assert below guards drift).
+ * posix_spawn fills name/argv/fd_list, cap_mask = ~0 (inherit all, the kernel
+ * intersects with the parent), and zero-fills the rest (identity/allowance
+ * inherit; perm_flags = 0). */
+struct pouch_spawn_args {
+	unsigned long long name_va;        /* 0  */
+	unsigned long long argv_data_va;   /* 8  */
+	unsigned long long fd_list_va;     /* 16 */
+	unsigned int name_len;             /* 24 */
+	unsigned int argv_data_len;        /* 28 */
+	unsigned int argc;                 /* 32 */
+	unsigned int fd_count;             /* 36 */
+	unsigned int perm_flags;           /* 40 */
+	unsigned int _pad_envp;            /* 44 -- must be 0 (reserved envp_len) */
+	unsigned long long cap_mask;       /* 48 */
+	unsigned int principal_id;         /* 56 */
+	unsigned int primary_gid;          /* 60 */
+	unsigned long long supp_gids_va;   /* 64 */
+	unsigned int supp_gid_count;       /* 72 */
+	unsigned int identity_flags;       /* 76 */
+	unsigned long long allowance_va;   /* 80 */
+	unsigned int allowance_flags;      /* 88 */
+	unsigned int _pad_allow;           /* 92 -- must be 0 */
+};
+_Static_assert(sizeof(struct pouch_spawn_args) == 96,
+	"struct pouch_spawn_args must match the kernel sys_spawn_args ABI");
+
+/* Shared helpers (_pouch_process.c). */
+hidden int __pouch_pipe(int fd[2]);
+hidden int __pouch_wait(int pid, int *status, int options);
+
+#endif /* POUCH_PROCESS_H */
