--- a/src/internal/_pouch_signal.h
+++ b/src/internal/_pouch_signal.h
@@ -0,0 +1,122 @@
+/* pouch — POSIX signals over Thylacine notes (P6-pouch-signals, sub-chunk
+ * 13b). The boundary-line layer that retargets musl's src/signal/ from
+ * Linux's rt_sigaction / rt_sigprocmask / tkill / rt_sigreturn onto the
+ * five kernel note syscalls (NOTE_OPEN / NOTIFY / NOTED / POSTNOTE /
+ * NOTE_MASK; numbers 44-48 per kernel/include/thylacine/syscall.h).
+ *
+ * Design: POUCH-DESIGN.md section 6.4 + ARCH section 7.6.1-7.6.8. Plan 9
+ * notes are string-named and causally-ordered; pouch translates the small
+ * set of POSIX signals real daemons need (SIGINT, SIGTERM, SIGPIPE,
+ * SIGCHLD) onto the kernel's v1.0 supported set ("interrupt", "kill",
+ * "pipe", "child_exit"). The translation is many-to-one for INT+TERM
+ * (both map to "interrupt" at v1.0; documented limitation) and one-to-
+ * one for the others. SIGKILL/SIGSTOP cannot be caught; sigaction()
+ * returns EINVAL for them per POSIX. All other signums return EINVAL.
+ *
+ * Per-thread shadow + per-Proc sigtab: the kernel's note_mask is per-
+ * Thread (POSIX pthread_sigmask semantics); pouch keeps a __thread shadow
+ * to support SIG_BLOCK / SIG_UNBLOCK read-modify-write. The sigaction
+ * table is per-Proc (POSIX sigaction semantics); pouch keeps it in a
+ * static array indexed by signum.
+ *
+ * Bootstrap handler: at constructor time we register __pouch_note_handler
+ * via SYS_NOTIFY. The kernel calls it Plan-9-style with x0 = pointer to
+ * 16-byte note name on the user stack + x1 = note arg. We dispatch by
+ * name to the user-registered sigaction handler and end with
+ * SYS_NOTED(NCONT) — the synchronous-handler ABI is hidden from POSIX
+ * source. POSIX programs see standard sigaction + raise + kill.
+ *
+ * SIGPIPE default-mask at startup (POUCH-DESIGN section 6.4 [RESOLVED
+ * 6.4]): the constructor sets the main thread's note_mask to
+ * NOTE_BIT_PIPE so a write-to-closed-pipe returns EPIPE without
+ * delivering a SIGPIPE — modern-daemon-friendly default. A subsequent
+ * sigaction(SIGPIPE, &sa) with a non-default handler clears the mask
+ * bit (so the note is delivered + the handler fires).
+ *
+ * v1.0 limitations documented in docs/reference/83-pouch-signals.md
+ * (created at sub-chunk 13b):
+ *   - SIGINT and SIGTERM share "interrupt" — last-registered-wins for
+ *     mixed sigaction calls. A program registering BOTH gets the SIGINT
+ *     handler preferred (defense-in-depth in the bootstrap dispatcher).
+ *   - Child threads spawned via pthread_create start with note_mask=0;
+ *     parent thread's mask does NOT propagate. POSIX says inheritance;
+ *     v1.0 documented limitation. Programs that need POSIX-correct
+ *     inheritance set the child's mask in the entry function manually.
+ *   - sigsetjmp/siglongjmp do NOT preserve signal masks (the
+ *     sigsetjmp_tail.c path still hits the SYS_rt_sigprocmask = 0xFFFF
+ *     sentinel → -ENOSYS). v1.x extension.
+ *   - sigaltstack returns ENOSYS (alt-stack not supported at v1.0).
+ *   - sigpending / sigtimedwait / sigqueue / sigsuspend return ENOSYS.
+ *   - SIGRT* (real-time signals) and per-signal-info (siginfo_t) not
+ *     supported. sigqueue() returns ENOSYS.
+ *   - SIGABRT not in the v1.0 supported set; abort() falls through to
+ *     its plain-_Exit fallback path (no handler ever fires).
+ */
+
+#ifndef _POUCH_SIGNAL_H
+#define _POUCH_SIGNAL_H
+
+#include <signal.h>
+#include <stdint.h>
+#include <features.h>
+
+/* Mirror NOTE_BIT_* from kernel/include/thylacine/notes.h. The kernel
+ * header isn't pulled into the pouch build (pouch is built against its
+ * own sysroot); these values are part of the SYS_NOTE_MASK ABI and pinned
+ * in ARCH section 7.6.7. */
+#define POUCH_NOTE_BIT_INTERRUPT   (1u << 0)
+#define POUCH_NOTE_BIT_KILL        (1u << 1)
+#define POUCH_NOTE_BIT_PIPE        (1u << 2)
+#define POUCH_NOTE_BIT_CHILD_EXIT  (1u << 3)
+#define POUCH_NOTE_MASK_SUPPORTED  0x0fu
+
+/* SYS_NOTED arg semantics (matches kernel/include/thylacine/notes.h
+ * "SYS_NOTED arg semantics" docblock, R4-F6 audit close). */
+#define POUCH_SYS_NOTED_NCONT  0u   /* restore saved user context + resume */
+#define POUCH_SYS_NOTED_NDFLT  1u   /* take the note's default action (exits) */
+
+/* Kernel pushes exactly NOTE_NAME_MAX (= 16) bytes of the note name onto
+ * the user stack. POSIX programs never reach into this directly; the
+ * bootstrap handler does the bounded compare via __pouch_note_name_eq. */
+#define POUCH_NOTE_NAME_MAX  16
+
+/* The per-Proc sigaction table. v1.0 supported set: SIGINT, SIGTERM,
+ * SIGPIPE, SIGCHLD. Other slots are unused (sigaction returns EINVAL).
+ * Indexed by signum (1..NSIG-1). Slot 0 unused. */
+extern hidden struct sigaction __pouch_sigtab[_NSIG];
+
+/* Per-thread shadow of the kernel note mask. Pouch is the sole writer.
+ * TLS so each thread has its own copy (matches the kernel's per-Thread
+ * note_mask). Initialized to 0; the constructor sets the main thread's
+ * to POUCH_NOTE_BIT_PIPE. */
+extern hidden __thread uint64_t __pouch_note_mask_shadow;
+
+/* Translate POSIX signum -> note name string. Writes the static-storage
+ * canonical name to *out on success. Returns 0 on the v1.0 supported
+ * set (SIGINT/SIGTERM -> "interrupt"; SIGKILL -> "kill"; SIGPIPE ->
+ * "pipe"; SIGCHLD -> "child_exit"), -1 on unsupported. */
+hidden int __pouch_sig_to_note(int sig, const char **out);
+
+/* The bootstrap async-handler. Registered with SYS_NOTIFY at startup;
+ * the kernel calls this at EL0-return tail when a note is dispatched.
+ * Plan-9-style ABI: x0 = pointer to 16-byte note name on user stack;
+ * x1 = note arg. NEVER returns normally — ends with SYS_NOTED. */
+hidden void __pouch_note_handler(const char *name, unsigned int arg);
+
+/* Bounded name compare: the kernel pushes exactly POUCH_NOTE_NAME_MAX
+ * (= 16) bytes onto the user stack, NUL-padded. Returns 1 if `name`'s
+ * bytes match `literal`'s within the bound (the literal is NUL-
+ * terminated), 0 otherwise. */
+hidden int __pouch_note_name_eq(const char *name, const char *literal);
+
+/* Translate a POSIX sigset_t to NOTE_BIT_* mask (only supported bits
+ * survive translation; unsupported signals are silently dropped — POSIX
+ * specifies that pthread_sigmask attempts to block SIGKILL/SIGSTOP are
+ * undefined-behaviour or silently ignored). */
+hidden uint64_t __pouch_sigset_to_note(const sigset_t *s);
+
+/* Reverse: NOTE_BIT_* mask -> POSIX sigset_t. The result is a synthetic
+ * sigset that callers see when reading the "old" mask. */
+hidden void __pouch_note_to_sigset(uint64_t m, sigset_t *out);
+
+#endif
--- a/src/signal/_pouch_signal.c
+++ b/src/signal/_pouch_signal.c
@@ -0,0 +1,188 @@
+/* pouch — POSIX signal layer over Thylacine notes (P6-pouch-signals,
+ * sub-chunk 13b). See src/internal/_pouch_signal.h for the design
+ * preamble. This file holds:
+ *   - the per-Proc sigaction table (__pouch_sigtab)
+ *   - the per-thread note-mask shadow (__pouch_note_mask_shadow)
+ *   - the signum<->note name translation helpers
+ *   - the bootstrap async-handler (__pouch_note_handler)
+ *   - the constructor that registers it + sets the SIGPIPE default mask
+ */
+
+#include <signal.h>
+#include <stdint.h>
+#include <string.h>
+
+#include "syscall.h"
+#include "pthread_impl.h"
+#include "libc.h"
+#include "_pouch_signal.h"
+
+hidden struct sigaction __pouch_sigtab[_NSIG];
+hidden __thread uint64_t __pouch_note_mask_shadow;
+
+hidden int __pouch_note_name_eq(const char *name, const char *literal)
+{
+    /* The kernel zero-pads the 16-byte name buffer (struct Note.name) on
+     * the user stack. Bounded compare protects against unterminated
+     * names; the literal is NUL-terminated within 16 bytes for every
+     * v1.0 supported entry ("interrupt"=9, "kill"=4, "pipe"=4,
+     * "child_exit"=10 all fit). */
+    for (int i = 0; i < POUCH_NOTE_NAME_MAX; i++) {
+        char a = name[i];
+        char b = literal[i];
+        if (a != b) return 0;
+        if (b == 0) return 1;
+    }
+    /* Reached end of bound — `name` matched `literal` byte-for-byte up
+     * to the cap without seeing literal's NUL. Defense-in-depth: only
+     * happens for a 16-byte literal which we don't have at v1.0; return
+     * match. */
+    return 1;
+}
+
+hidden int __pouch_sig_to_note(int sig, const char **out)
+{
+    /* v1.0 supported set per POUCH-DESIGN.md section 6.4. SIGINT and
+     * SIGTERM share "interrupt" — a programs-side limitation documented
+     * in docs/reference/83-pouch-signals.md. */
+    switch (sig) {
+    case SIGINT:
+    case SIGTERM:
+        *out = "interrupt";
+        return 0;
+    case SIGKILL:
+        *out = "kill";
+        return 0;
+    case SIGPIPE:
+        *out = "pipe";
+        return 0;
+    case SIGCHLD:
+        *out = "child_exit";
+        return 0;
+    default:
+        return -1;
+    }
+}
+
+hidden uint64_t __pouch_sigset_to_note(const sigset_t *s)
+{
+    uint64_t m = 0;
+    /* sigismember returns 1/0/-1 (-1 on bad arg). Treat -1 as not-set. */
+    if (sigismember(s, SIGINT) == 1 || sigismember(s, SIGTERM) == 1)
+        m |= POUCH_NOTE_BIT_INTERRUPT;
+    /* SIGKILL/SIGSTOP cannot be blocked; we silently drop them. */
+    if (sigismember(s, SIGPIPE) == 1) m |= POUCH_NOTE_BIT_PIPE;
+    if (sigismember(s, SIGCHLD) == 1) m |= POUCH_NOTE_BIT_CHILD_EXIT;
+    return m;
+}
+
+hidden void __pouch_note_to_sigset(uint64_t m, sigset_t *out)
+{
+    sigemptyset(out);
+    if (m & POUCH_NOTE_BIT_INTERRUPT) {
+        sigaddset(out, SIGINT);
+        sigaddset(out, SIGTERM);
+    }
+    if (m & POUCH_NOTE_BIT_PIPE)       sigaddset(out, SIGPIPE);
+    if (m & POUCH_NOTE_BIT_CHILD_EXIT) sigaddset(out, SIGCHLD);
+}
+
+hidden void __pouch_note_handler(const char *name, unsigned int arg)
+{
+    (void)arg;     /* v1.0 doesn't propagate the note arg through to the
+                    * POSIX handler — siginfo_t carries it on Linux but
+                    * pouch's POSIX surface is the legacy `void (int)`
+                    * shape; the modern fd-shaped path (SYS_NOTE_OPEN) is
+                    * the way to access full note records. */
+
+    int sig = -1;
+    if (__pouch_note_name_eq(name, "interrupt")) {
+        /* SIGINT and SIGTERM both map to "interrupt" at v1.0. Prefer
+         * SIGINT's user handler if installed; fall back to SIGTERM.
+         * (Documented limitation; v1.x extension: per-name notes.) */
+        void (*hi)(int) = __pouch_sigtab[SIGINT].sa_handler;
+        void (*ht)(int) = __pouch_sigtab[SIGTERM].sa_handler;
+        if (hi && hi != SIG_DFL && hi != SIG_IGN)        sig = SIGINT;
+        else if (ht && ht != SIG_DFL && ht != SIG_IGN)   sig = SIGTERM;
+        else                                              sig = SIGINT;
+    } else if (__pouch_note_name_eq(name, "pipe")) {
+        sig = SIGPIPE;
+    } else if (__pouch_note_name_eq(name, "child_exit")) {
+        sig = SIGCHLD;
+    } else if (__pouch_note_name_eq(name, "kill")) {
+        /* `kill` is non-catchable per N-4 (notes.h). The kernel calls
+         * exits("killed") directly; this branch is defense-in-depth in
+         * case a future extension routes "kill" through the handler. */
+        sig = SIGKILL;
+    }
+
+    if (sig < 0) {
+        /* Unknown note name (kernel only delivers supported names; this
+         * is defense-in-depth against future ABI drift). NCONT resumes
+         * the interrupted user code. */
+        __syscall(SYS_noted, POUCH_SYS_NOTED_NCONT);
+        for (;;);     /* unreachable — SYS_NOTED(NCONT) never returns */
+    }
+
+    void (*h)(int) = __pouch_sigtab[sig].sa_handler;
+
+    if (h == SIG_DFL || h == 0) {
+        /* Default action for the v1.0 supported set:
+         *   SIGINT / SIGTERM / SIGPIPE: terminate (NDFLT → kernel exits)
+         *   SIGCHLD: ignore (NCONT — child_exit's default per POSIX)
+         *   SIGKILL: terminate (NDFLT; though this branch is unreachable
+         *            because the kernel handles kill before delivery)
+         *
+         * F2 audit close (sub-chunk 13b): NDFLT is refused by the kernel
+         * in a multi-thread Proc (R3-F2 of 13a) because exits() requires
+         * live_peers == 0 — cross-thread shootdown is a v1.x extension.
+         * Without a fallback, a worker Thread receiving a default-action
+         * note (e.g., a SIGPIPE delivered to a worker whose note_mask
+         * doesn't block pipe — documented limitation that child threads
+         * don't inherit the constructor's BIT_PIPE mask) would NDFLT-fail
+         * and drop into for(;;), wedging the Thread. The fallback below
+         * NCONT-resumes on NDFLT refusal so the Thread continues. v1.x
+         * cross-thread shootdown lets NDFLT terminate the whole Proc. */
+        if (sig == SIGCHLD) {
+            __syscall(SYS_noted, POUCH_SYS_NOTED_NCONT);
+        } else {
