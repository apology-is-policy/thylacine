+
+int pouch_sock_poll_fd(int fd)
+{
+    /* Untagged fd: poll it directly (a raw kernel handle). */
+    if ((fd & POUCH_SOCK_TAG) == 0) return fd;
+
+    int i = slot_idx(fd);
+    if (i < 0) {
+        errno = EBADF;
+        return -1;
+    }
+
+    /* Capture the poll-relevant fields under the lock (the locked-read
+     * discipline of pouch_sock_kernel_fd). For FAM_UNIX the poll target is
+     * kernel_fd (the /srv byte stream); for FAM_INET it is the readiness fd,
+     * which may need a lazy open below. */
+    LOCK(g_lock);
+    int in_use  = g_table[i].in_use;
+    int is_inet = in_use && g_table[i].family == POUCH_SOCK_FAM_INET;
+    int rfd     = in_use ? g_table[i].ready_fd : -1;
+    int kfd     = (in_use && g_table[i].state != POUCH_SOCK_FRESH)
+                      ? g_table[i].kernel_fd : -1;
+    int proto   = g_table[i].net_proto;
+    int n       = g_table[i].conn_n;
+    UNLOCK(g_lock);
+
+    if (!in_use) {
+        errno = EBADF;
+        return -1;
+    }
+
+    if (!is_inet) {
+        /* AF_UNIX: poll the /srv byte stream (kernel devsrv .poll). A FRESH
+         * slot has no kernel_fd yet -> -1 (POLLNVAL), the 0015 behavior. */
+        if (kfd < 0) errno = ENOTCONN;
+        return kfd;
+    }
+
+    /* AF_INET: the poll target is the QTPOLL-marked /net/<proto>/N/ready
+     * sibling, NOT the data fd (a regular dev9p file is POSIX always-ready).
+     * The ready file exists for any cloned connection N (socket() always
+     * sets conn_n), so it is openable in every state -- netd's readiness
+     * reflects the connection's state. Open it lazily, once. */
+    if (rfd >= 0) return rfd;
+    if (n < 0) {
+        errno = EBADF;   /* a FAM_INET slot always has conn_n; defensive */
+        return -1;
+    }
+
+    int opened = pouch_net_open_conn_file(proto, n, "ready",
+                                          (int)POUCH_SRV_OREAD);
+    if (opened < 0) {
+        errno = ENETDOWN;
+        return -1;
+    }
+
+    /* Publish under the lock. Single-user-per-socket is the inherited
+     * discipline (0006/0016/0017's direct slot writes), but a peer thread
+     * legitimately poll()ing the SAME fd may have won the open race, or the
+     * socket may have closed while we held no lock -- reconcile both. */
+    LOCK(g_lock);
+    if (!g_table[i].in_use) {
+        UNLOCK(g_lock);
+        __syscall(SYS_close, opened);
+        errno = EBADF;
+        return -1;
+    }
+    if (g_table[i].ready_fd >= 0) {
+        int winner = g_table[i].ready_fd;
+        UNLOCK(g_lock);
+        __syscall(SYS_close, opened);
+        return winner;
+    }
+    g_table[i].ready_fd = opened;
+    UNLOCK(g_lock);
+    return opened;
 }
 
