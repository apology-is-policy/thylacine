 #define POUCH_SRV_OPATH      0x80u
 #define POUCH_SRV_DMSRVBYTE  0x02000000u
+#define POUCH_SRV_DMSRVBULK  0x01000000u /* CF-3 B: the bulk ring class */
+/* The SO_SNDBUF/SO_RCVBUF threshold at or above which a pre-bind
+ * setsockopt marks the socket BULK: its bind()-time service post carries
+ * DMSRVBULK, so every connection gets 128 KiB-frame rings and the
+ * kernel-attached mount negotiates a 128 KiB msize (CONCURRENT-FS.md
+ * CF-3 B). Below the threshold the option is an accepted no-op (POSIX
+ * treats the buffer sizes as advisory hints). */
+#define POUCH_SRV_BULK_MIN   (128 * 1024)
 
