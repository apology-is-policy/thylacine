+/* pouch — AF_UNIX SOCK_STREAM userspace slot table (P6-pouch-sockets,
+ * sub-chunk 12). Kept entirely in pouch; the kernel knows nothing
+ * about POSIX sockets. socket() returns a tagged fd carrying a slot
+ * index; bind / listen / connect / accept / getsockopt(SO_PEERCRED)
+ * /close / read / write check the tag and dispatch through the slot.
+ *
+ * Design: POUCH-DESIGN.md section 6.2. The translation table —
+ *   socket(AF_UNIX, SOCK_STREAM, 0)  pouch_sock_alloc()
+ *   bind(fd, /srv/<name>)            SYS_post_service(<name>)
+ *   listen(fd, backlog)              no-op (kernel registry backlog)
+ *   accept(fd)                       SYS_srv_accept(listener_h) ->
+ *                                    raw kernel Spoor fd (NOT pouch-
+ *                                    tagged — server-side I/O bypasses
+ *                                    the shim).
+ *   connect(fd, /srv/<name>)         SYS_srv_connect(<name>, NULL, 0)
+ *                                    (path_len == 0 == the "no Twalk"
+ *                                    case in kernel/srvconn.c — Tversion
+ *                                    + Tattach only, byte stream at
+ *                                    root_fid)
+ *   getsockopt(fd, SOL_SOCKET, SO_PEERCRED, &ucred, &len)
+ *                                    SYS_srv_peer(conn_h, &out) ->
+ *                                    ucred-shaped marshal
+ *   read(fd) / write(fd) / close(fd)
+ *                                    pouch_sock_kernel_fd(fd) ->
+ *                                    SYS_read / SYS_write / SYS_close
+ *
+ * Tag encoding: POUCH_SOCK_TAG | slot_idx, with slot_idx in
+ * [0, POUCH_SOCK_MAX). The tag bit (0x40000000) sits above the
+ * kernel's PROC_HANDLE_MAX so no real kernel fd ever overlaps a
+ * pouch socket fd.
+ *
+ * Constraints accepted at v1.0:
+ *   - Per-Proc concurrent /srv client cap = 1 (SRV_CONN_PER_PROC_MAX,
+ *     kernel/srvconn.c). The proving binary uses one client at a time.
+ *   - AF_INET / AF_INET6 unsupported (EAFNOSUPPORT — network phase).
+ *   - SOCK_DGRAM / SOCK_SEQPACKET unsupported (EPROTONOSUPPORT).
+ *   - SOCK_NONBLOCK / O_NONBLOCK silently no-op (v1.0 sockets are
+ *     blocking; nonblocking sockets need POLLOUT plumbing in SYS_POLL,
+ *     deferred).
+ *   - socketpair / shutdown / getpeername / getsockname / recv* /
+ *     send* fall through to the syscall-seam 0xFFFF sentinel —
+ *     ENOSYS at v1.0 (POUCH-DESIGN.md section 6.2).
+ *
+ * Naming: the leading underscore marks this header as pouch-internal
+ * (not for POSIX programs to include).
+ */
+#ifndef _POUCH_SOCKET_H
+#define _POUCH_SOCKET_H
+
+#include <sys/socket.h>
+#include <sys/un.h>
+
+/* Tag bit identifying a pouch-managed socket fd. Sits in the
+ * unused-by-kernel bit range above PROC_HANDLE_MAX. */
+#define POUCH_SOCK_TAG       0x40000000
+
+/* Upper bound on concurrent unbound + listening + connecting sockets
+ * in one Proc. /srv listener count is bounded by the kernel registry;
+ * /srv client count is hard-capped at 1 per Proc. POUCH_SOCK_MAX of 8
+ * is generous for v1.0 servers. */
+#define POUCH_SOCK_MAX       8
+
+enum pouch_sock_state {
+    POUCH_SOCK_FRESH = 0,        /* socket() returned; no bind/connect yet  */
+    POUCH_SOCK_LISTENING,        /* bind() + listen() done; kernel_fd is    */
+                                 /*   a KObj_Srv listener handle            */
+    POUCH_SOCK_CONNECTED,        /* connect() done; kernel_fd is a KObj_Srv */
+                                 /*   client-side SrvConn handle            */
+};
+
+struct pouch_sock_slot {
+    int                       in_use;
+    enum pouch_sock_state     state;
+    int                       kernel_fd;  /* -1 in FRESH */
+};
+
+/* pouch_sock_alloc — claim a fresh slot.
+ *
+ * On success returns a tagged fd >= POUCH_SOCK_TAG; the user of this
+ * value MUST eventually free the slot via close() (which routes
+ * through pouch_sock_close).
+ *
+ * On failure returns -1, errno = EMFILE (no free slot).
+ */
+int pouch_sock_alloc(void);
+
+/* pouch_sock_resolve — fd to slot pointer. NULL if fd is not a
+ * pouch-tagged value, or the slot is vacant. The returned pointer
+ * remains valid until close() (the table entries are static). */
+struct pouch_sock_slot *pouch_sock_resolve(int fd);
+
+/* pouch_sock_kernel_fd — fd to the slot's kernel handle.
+ *
+ * For an UNTAGGED fd: returns fd unchanged (the pass-through case —
+ * read/write/close on a raw kernel handle stays raw).
+ *
+ * For a TAGGED fd: returns the kernel handle if the slot is in
+ * LISTENING or CONNECTED state. Returns -1 if the slot is FRESH (no
+ * kernel handle yet) or vacant. The caller is expected to surface
+ * EBADF / ENOTCONN on -1 per POSIX.
+ *
+ * No lock held across the read; the kernel_fd value is captured.
+ */
+int pouch_sock_kernel_fd(int fd);
+
+/* pouch_sock_close — close a tagged fd's slot. Closes the kernel
+ * handle (if any) via SYS_close and marks the slot vacant. Returns
+ * 0 on success, -1 with errno set on bad fd. The caller (close in
+ * src/unistd/close.c) routes here only for tagged fds; untagged fds
+ * pass straight through to SYS_close. */
+int pouch_sock_close(int fd);
+
+#endif /* _POUCH_SOCKET_H */
