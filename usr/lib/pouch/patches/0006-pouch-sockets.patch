+/* pouch — AF_UNIX SOCK_STREAM userspace slot table implementation
+ * (P6-pouch-sockets, sub-chunk 12). See src/internal/_pouch_socket.h
+ * for the design + the translation table.
+ *
+ * Thread-safety: the table is a process-global resource (pthread peers
+ * share it). All structural changes — slot claim, slot vacate, state
+ * transitions, kernel_fd writes — happen under g_lock. Reads of
+ * kernel_fd value through pouch_sock_kernel_fd() capture the integer
+ * under the lock, so a parallel close() releasing the slot does not
+ * race the read out.
+ */
+#include "_pouch_socket.h"
+#include "syscall.h"
+#include "lock.h"
+#include "libc.h"
+#include <errno.h>
+
+static struct pouch_sock_slot g_table[POUCH_SOCK_MAX];
+static volatile int           g_lock[1];
+
+/* slot_idx — fd to slot index, with bounds + tag check. Returns -1
+ * for any untagged fd or out-of-range slot. */
+static inline int slot_idx(int fd)
+{
+    if ((fd & POUCH_SOCK_TAG) == 0) return -1;
+    int i = fd & ~POUCH_SOCK_TAG;
+    if (i < 0 || i >= POUCH_SOCK_MAX) return -1;
+    return i;
+}
+
+int pouch_sock_alloc(void)
+{
+    LOCK(g_lock);
+    for (int i = 0; i < POUCH_SOCK_MAX; i++) {
+        if (!g_table[i].in_use) {
+            g_table[i].in_use    = 1;
+            g_table[i].state     = POUCH_SOCK_FRESH;
+            g_table[i].kernel_fd = -1;
+            UNLOCK(g_lock);
+            return POUCH_SOCK_TAG | i;
+        }
+    }
+    UNLOCK(g_lock);
+    errno = EMFILE;
+    return -1;
+}
+
+struct pouch_sock_slot *pouch_sock_resolve(int fd)
+{
+    int i = slot_idx(fd);
+    if (i < 0) return 0;
+    LOCK(g_lock);
+    int alive = g_table[i].in_use;
+    UNLOCK(g_lock);
+    if (!alive) return 0;
+    return &g_table[i];
+}
+
+int pouch_sock_kernel_fd(int fd)
+{
+    /* Untagged fd: pass through unchanged (read/write/close on a raw
+     * kernel handle stays raw). */
+    if ((fd & POUCH_SOCK_TAG) == 0) return fd;
+
+    int i = slot_idx(fd);
+    if (i < 0) {
+        errno = EBADF;
+        return -1;
+    }
+
+    /* F8 close (P6-pouch-sockets audit): capture both the slot's
+     * in_use and the kernel_fd INSIDE the locked region, then set
+     * errno from the local. The earlier shape read in_use AGAIN
+     * outside the lock to decide the errno class — a parallel
+     * close() racing the unlock could flip it from 1 to 0, mis-
+     * categorizing the errno as EBADF when it should be ENOTCONN
+     * (or vice versa). User-facing minor weirdness, no data harm. */
+    LOCK(g_lock);
+    int in_use = g_table[i].in_use;
+    int k      = -1;
+    if (in_use && g_table[i].state != POUCH_SOCK_FRESH) {
+        k = g_table[i].kernel_fd;
+    }
+    UNLOCK(g_lock);
+
+    if (k < 0) errno = in_use ? ENOTCONN : EBADF;
+    return k;
+}
+
+int pouch_sock_close(int fd)
+{
+    int i = slot_idx(fd);
+    if (i < 0) {
+        errno = EBADF;
+        return -1;
+    }
+
+    LOCK(g_lock);
+    if (!g_table[i].in_use) {
+        UNLOCK(g_lock);
+        errno = EBADF;
+        return -1;
+    }
+    int k = g_table[i].kernel_fd;
+    g_table[i].in_use    = 0;
+    g_table[i].state     = POUCH_SOCK_FRESH;
+    g_table[i].kernel_fd = -1;
+    UNLOCK(g_lock);
+
+    /* The kernel handle outlives the slot release for one instant — a
+     * peer thread cannot observe the slot as still-alive between the
+     * UNLOCK and the SYS_close, so this is a safe order. SYS_close's
+     * return is not surfaced to the user: POSIX close() returns 0 even
+     * on a kernel-side teardown error (errno-on-close is advisory). */
+    if (k >= 0) __syscall(SYS_close, k);
+    return 0;
+}
