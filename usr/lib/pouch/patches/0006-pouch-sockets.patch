+/* pouch — accept(2) for AF_UNIX SOCK_STREAM (P6-pouch-sockets,
+ * sub-chunk 12). Calls SYS_srv_accept on the slot's listener handle
+ * and returns the resulting kernel-minted Spoor fd DIRECTLY.
+ *
+ * The accepted fd is NOT pouch-tagged — subsequent read / write /
+ * close on it route through the syscall-seam directly (no slot
+ * dispatch). This keeps the server-side I/O path on the same
+ * SYS_read / SYS_write fast path as any other Spoor handle.
+ *
+ * The kernel-side sockaddr writeback is minimal: AF_UNIX sockets in
+ * the Thylacine model have no peer path — peer identity is
+ * SO_PEERCRED, kernel-stamped from SYS_srv_peer. If addr/len are
+ * non-NULL we write back a zero-sun_path AF_UNIX sockaddr.
+ */
 #include <sys/socket.h>
+#include <sys/un.h>
+#include <errno.h>
+#include <string.h>
+#include "_pouch_socket.h"
 #include "syscall.h"
 
-int accept(int fd, struct sockaddr *restrict addr, socklen_t *restrict len)
+int accept(int fd, struct sockaddr *restrict addr,
+           socklen_t *restrict len)
 {
-	return socketcall_cp(accept, fd, addr, len, 0, 0, 0);
+	struct pouch_sock_slot *slot = pouch_sock_resolve(fd);
+	if (!slot) {
+		errno = EBADF;
+		return -1;
+	}
+	if (slot->state != POUCH_SOCK_LISTENING) {
+		errno = EINVAL;
+		return -1;
+	}
+
+	long r = __syscall(SYS_srv_accept, slot->kernel_fd);
+	if (r < 0) {
+		errno = ECONNABORTED;
+		return -1;
+	}
+
+	if (addr && len && *len >= (socklen_t)sizeof(sa_family_t)) {
+		struct sockaddr_un un;
+		memset(&un, 0, sizeof(un));
+		un.sun_family = AF_UNIX;
+		socklen_t copy_len = (*len < (socklen_t)sizeof(un))
+			? *len : (socklen_t)sizeof(un);
+		memcpy(addr, &un, (size_t)copy_len);
+		*len = (socklen_t)sizeof(sa_family_t);
+	} else if (len) {
+		*len = 0;
+	}
+
+	return (int)r;
 }
