- * abstraction for tearing down a registered service (close on the
- * server's listener fd releases the slot). Returning 0 satisfies
- * the idiomatic-prep "remove any stale socket file" dance without
- * making any kernel call.
- *
- * Non-/srv paths fall through to the original syscall(SYS_unlinkat)
- * delegation (ENOSYS via SYS_unlinkat = 0xFFFF today).
- *
- * See 0014-pouch-srv-stubs.patch for the design rationale. */
 #include <unistd.h>
 #include <fcntl.h>
-#include <string.h>
 #include "syscall.h"
 
 int unlink(const char *path)
 {
-	if (path) {
-		static const char prefix[] = "/srv/";
-		if (strncmp(path, prefix, sizeof(prefix) - 1) == 0) {
-			return 0;
-		}
-	}
-#ifdef SYS_unlink
-	return syscall(SYS_unlink, path);
-#else
-	return syscall(SYS_unlinkat, AT_FDCWD, path, 0);
-#endif
+	/* pouch (0024): route through the boundary-line unlinkat() -- the
+	 * raw SYS_unlinkat is the unwired 0xFFFF sentinel on Thylacine. */
+	return unlinkat(AT_FDCWD, path, 0);
