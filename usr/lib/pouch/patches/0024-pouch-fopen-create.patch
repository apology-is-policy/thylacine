diff a/src/unistd/unlinkat.c b/src/unistd/unlinkat.c
--- a/src/unistd/unlinkat.c
+++ b/src/unistd/unlinkat.c
@@ -1,7 +1,83 @@
+/* pouch boundary-line replacement (task #50, patch 0024).
+ *
+ * unlinkat() over Thylacine's SYS_UNLINK (= 58, FS-gamma): split the
+ * path, T_OPATH-open the parent directory (born-R|W -- the create/
+ * unlink write authority; #81 blocks only its byte I/O), unlink the
+ * single base component. AT_REMOVEDIR maps to SYS_UNLINK_REMOVEDIR
+ * (rmdir). AT_FDCWD + absolute paths only, the 0021 openat posture.
+ * The kernel answers the real -errno (EISDIR/ENOENT/EACCES/...). */
 #include <unistd.h>
+#include <fcntl.h>
+#include <errno.h>
+#include <string.h>
 #include "syscall.h"
 
+#define POUCH_WALK_FROM_ROOT  ((long)(-1))
+#define POUCH_OPATH           0x80u
+#define POUCH_PATH_MAX        1024u
+#define POUCH_NAME_MAX        64u
+#define POUCH_UNLINK_REMOVEDIR 0x200u
+
 int unlinkat(int fd, const char *path, int flag)
 {
-	return syscall(SYS_unlinkat, fd, path, flag);
+	/* The 0014 /srv short-circuit, PRESERVED (this patch replaces the
+	 * 0014 unlink.c body, so the carve moves here -- the single
+	 * chokepoint unlink/rmdir/remove all route through): a /srv/<name>
+	 * has no file artifact (the per-boot kernel registry; the slot
+	 * releases with the listener fd), so the idiomatic pre-bind
+	 * "remove any stale socket" unlink answers 0 without a kernel
+	 * call -- stratumd's stm_stratumd_listen_unix prologue treats any
+	 * non-ENOENT failure as fatal. AT_REMOVEDIR falls through (an
+	 * honest error; rmdir of a /srv entry is not a thing). */
+	if (path && flag == 0) {
+		static const char prefix[] = "/srv/";
+		if (strncmp(path, prefix, sizeof(prefix) - 1) == 0)
+			return 0;
+	}
+	if (fd != AT_FDCWD) {
+		errno = ENOTSUP;
+		return -1;
+	}
+	if (flag & ~AT_REMOVEDIR) {
+		errno = EINVAL;
+		return -1;
+	}
+	if (!path) {
+		errno = EFAULT;
+		return -1;
+	}
+	if (path[0] != '/') {
+		errno = ENOTSUP;
+		return -1;
+	}
+	size_t len = strlen(path);
+	if (len > POUCH_PATH_MAX) {
+		errno = ENAMETOOLONG;
+		return -1;
+	}
+	/* Trailing slashes are legal on a directory target (rmdir("/a/")). */
+	size_t end = len;
+	while (end > 1 && path[end - 1] == '/') end--;
+	if (end == 1) {
+		errno = EBUSY;  /* "/" itself */
+		return -1;
+	}
+	size_t bstart = end;
+	while (bstart > 0 && path[bstart - 1] != '/') bstart--;
+	size_t blen = end - bstart;
+	if (blen > POUCH_NAME_MAX) {
+		errno = ENAMETOOLONG;
+		return -1;
+	}
+	size_t plen = bstart;
+	while (plen > 1 && path[plen - 1] == '/') plen--;
+
+	long parent = __syscall(SYS_open, POUCH_WALK_FROM_ROOT, path, plen,
+	                        POUCH_OPATH);
+	if (parent < 0)
+		return __syscall_ret(parent);
+	long r = __syscall(SYS_unlink_component, parent, path + bstart, blen,
+	                   (flag & AT_REMOVEDIR) ? POUCH_UNLINK_REMOVEDIR : 0u);
+	__syscall(SYS_close, parent);
+	return __syscall_ret(r);
 }
