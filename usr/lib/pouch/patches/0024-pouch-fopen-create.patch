diff a/src/stdio/remove.c b/src/stdio/remove.c
--- a/src/stdio/remove.c
+++ b/src/stdio/remove.c
@@ -1,19 +1,16 @@
 #include <stdio.h>
 #include <errno.h>
 #include <fcntl.h>
+#include <unistd.h>
 #include "syscall.h"
 
 int remove(const char *path)
 {
-#ifdef SYS_unlink
-	int r = __syscall(SYS_unlink, path);
-#else
-	int r = __syscall(SYS_unlinkat, AT_FDCWD, path, 0);
-#endif
-#ifdef SYS_rmdir
-	if (r==-EISDIR) r = __syscall(SYS_rmdir, path);
-#else
-	if (r==-EISDIR) r = __syscall(SYS_unlinkat, AT_FDCWD, path, AT_REMOVEDIR);
-#endif
-	return __syscall_ret(r);
+	/* pouch (0024): route through the boundary-line unlinkat(); the
+	 * kernel answers EISDIR for unlink-of-a-directory (9P unlinkat),
+	 * which selects the rmdir arm exactly as upstream. */
+	int r = unlinkat(AT_FDCWD, path, 0);
+	if (r && errno == EISDIR)
+		r = unlinkat(AT_FDCWD, path, AT_REMOVEDIR);
+	return r;
 }
