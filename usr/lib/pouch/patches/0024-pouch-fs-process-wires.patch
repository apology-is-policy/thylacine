diff --color -ruN musl-base/src/fcntl/_pouch_fs.c b/src/fcntl/_pouch_fs.c
--- a/src/fcntl/_pouch_fs.c	1970-01-01 01:00:00
+++ b/src/fcntl/_pouch_fs.c	2026-07-23 16:50:40
@@ -0,0 +1,50 @@
+/* pouch boundary-line shared FS substrate (CL-1a). See _pouch_fs.h. */
+#include <fcntl.h>
+#include <errno.h>
+#include <string.h>
+#include "syscall.h"
+#include "_pouch_fs.h"
+
+int __pouch_open_parent(int atfd, const char *path, const char **leaf)
+{
+	if (!path || !leaf) return -EFAULT;
+	if (atfd != AT_FDCWD) return -ENOTSUP;   /* AT_FDCWD only at v1.0 (P-3) */
+
+	size_t len = strnlen(path, POUCH_PATH_MAX + 1);
+	if (len == 0) return -ENOENT;
+	if (len > POUCH_PATH_MAX) return -ENAMETOOLONG;
+
+	/* Find the last '/'. Its right side is the leaf; its left side (or "."
+	 * when there is none) is the parent directory to open. */
+	const char *slash = 0;
+	for (size_t i = 0; i < len; i++)
+		if (path[i] == '/') slash = path + i;
+
+	char dir[POUCH_PATH_MAX + 1];
+	size_t dlen;
+	if (!slash) {
+		/* No '/': parent is the cwd. */
+		dir[0] = '.';
+		dlen = 1;
+		*leaf = path;
+	} else {
+		*leaf = slash + 1;
+		if (**leaf == '\0') return -EINVAL;   /* trailing slash: no leaf */
+		if (slash == path) {
+			/* Leaf directly under root ("/foo"). */
+			dir[0] = '/';
+			dlen = 1;
+		} else {
+			dlen = (size_t)(slash - path);
+			memcpy(dir, path, dlen);
+		}
+	}
+	dir[dlen] = '\0';
+
+	/* Open the parent O_PATH: born R|W (the A-1.7 navigation base the
+	 * FS-mutation primitives accept), resolved through stalk (cwd-join
+	 * for a relative dir). */
+	long fd = __syscall(SYS_thyla_open, POUCH_FROM_ROOT, dir, dlen, POUCH_OPATH);
+	if (fd < 0) return (int)fd;
+	return (int)fd;
+}
