diff --color -ruN musl-base/src/internal/_pouch_fs.h b/src/internal/_pouch_fs.h
--- a/src/internal/_pouch_fs.h	1970-01-01 01:00:00
+++ b/src/internal/_pouch_fs.h	2026-07-23 16:50:26
@@ -0,0 +1,54 @@
+#ifndef _POUCH_FS_H
+#define _POUCH_FS_H
+
+/* pouch boundary-line shared FS substrate (CL-1a; docs/LLVM-DESIGN.md §12).
+ *
+ * Thylacine's FS-mutation kernel syscalls (SYS_RENAME 57 / SYS_UNLINK 58 /
+ * SYS_WALK_CREATE 54) are PARENT-FD + leaf-name primitives, not path-based
+ * like their POSIX/Linux counterparts. The POSIX *at functions therefore
+ * split their path into (parent-dir, leaf), open the parent O_PATH (which
+ * SYS_open resolves through the full stalk walk -- per-component X-search,
+ * cwd-join for a relative path, LS-4), and hand (parent_fd, leaf) to the
+ * kernel primitive. __pouch_open_parent is that shared split-and-open.
+ *
+ * The including .c file must `#include "syscall.h"` BEFORE this header:
+ * that pulls musl's internal src/include/features.h, where the `hidden`
+ * visibility macro lives (the _pouch_socket.h precedent). */
+
+/* Thylacine kernel syscall numbers (the 0019 SYS_thyla_* self-contained
+ * idiom -- aarch64's LP64 table has no legacy aliases to repoint). */
+#define SYS_thyla_open         65   /* stalk full-path open (start_fd, path, len, omode) */
+#define SYS_thyla_stat         88   /* POUNCE walk-query (path, len, &t_stat) */
+#define SYS_thyla_wstat        59   /* metadata set (fd, valid, mode, uid, gid, size) */
+#define SYS_thyla_readdir      56   /* 9P Treaddir stream (fd, buf, len) */
+#define SYS_thyla_rename       57   /* (olddir_fd, old, oldlen, newdir_fd, new, newlen) */
+#define SYS_thyla_unlink       58   /* (parent_fd, name, len, flags) */
+#define SYS_thyla_walk_create  54   /* (parent_fd, name, len, omode, perm) */
+#define SYS_thyla_chdir        69   /* (path, len) */
+#define SYS_thyla_getcwd       70   /* (buf, len) -> len */
+#define SYS_thyla_getpid       72   /* () -> pid */
+
+/* SYS_open sentinels / omode (mirror kernel/include/thylacine/syscall.h). */
+#define POUCH_FROM_ROOT   ((long)-1)   /* SYS_WALK_OPEN_FROM_ROOT */
+#define POUCH_OREAD       0u
+#define POUCH_OWRITE      1u
+#define POUCH_ORDWR       2u
+#define POUCH_OPATH       0x80u        /* SYS_WALK_OPEN_OPATH: walk-only, born R|W */
+
+/* SYS_wstat valid-mask bits. */
+#define POUCH_WSTAT_MODE  (1u << 0)
+#define POUCH_WSTAT_SIZE  (1u << 3)
+
+/* SYS_walk_create / SYS_unlink flag bits. */
+#define POUCH_DMDIR       0x80000000u  /* SYS_WALK_CREATE_DMDIR */
+#define POUCH_REMOVEDIR   0x200u       /* SYS_UNLINK_REMOVEDIR */
+
+#define POUCH_PATH_MAX    1024u        /* SYS_OPEN_PATH_MAX */
+
+/* Open the PARENT directory of `path` (O_PATH, born R|W) and set *leaf to
+ * the final component within `path`. Returns the parent fd (>= 0) or a
+ * negative -errno. AT_FDCWD only (a real dirfd -> -ENOTSUP); a relative
+ * path resolves against the Territory cwd via SYS_open's FROM_ROOT arm. */
+hidden int __pouch_open_parent(int atfd, const char *path, const char **leaf);
+
+#endif
