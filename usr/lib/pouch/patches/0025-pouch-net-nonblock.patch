+int pouch_sock_readable(int fd)
+{
+    int rfd = pouch_sock_poll_fd(fd);
+    if (rfd < 0) return -1;   /* errno set by pouch_sock_poll_fd */
+
+    /* One 0-timeout kernel poll of the resolved target. Any nonzero revents
+     * (POLLIN, or POLLHUP/POLLERR which are reported regardless of events)
+     * counts as readable: the subsequent read resolves promptly. */
+    struct pollfd pf = { .fd = rfd, .events = POLLIN, .revents = 0 };
+    int r = syscall_cp(SYS_poll, &pf, 1, 0);
+    if (r < 0) return -1;     /* errno set by syscall_cp */
+    return (r > 0 && pf.revents != 0) ? 1 : 0;
+}
